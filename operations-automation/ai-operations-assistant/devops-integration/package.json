{
  "name": "goat-devops-integration",
  "version": "1.0.0",
  "description": "GOAT Network Agent ↔ AWS DevOps Agent Integration - Exposes packet-level diagnostic actions as an external tool",
  "private": true,
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:property": "vitest run --dir test/property",
    "test:unit": "vitest run --dir test/unit",
    "lint": "tsc --noEmit",
    "cdk": "cd infrastructure/cdk && npx cdk"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agent-runtime": "^3.750.0",
    "@aws-sdk/client-bedrock-agentcore": "^3.1072.0",
    "@aws-sdk/client-dynamodb": "^3.1072.0",
    "ajv": "^8.17.1",
    "aws-cdk-lib": "^2.219.0",
    "constructs": "^10.4.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^20.19.20",
    "@types/uuid": "^10.0.0",
    "aws-cdk": "^2.1030.0",
    "fast-check": "^3.23.2",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.1"
  }
}
