                </mxCell>
                <mxCell id="sc-g" value="G: Reachability Analyzer&lt;br&gt;    Asymetric trafic troubleshooting" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;fontSize=9;align=left;spacingLeft=8;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="810" y="180" width="300" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="sc-h" value="H: mtr / tcp traceroute&amp;nbsp;&lt;br&gt;Jitter/latency issue" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=9;align=left;spacingLeft=8;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="810" y="225" width="300" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="sc-i" value="I: TLS Traceroute&#10;    ACM cert domain ≠ client SNI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FF9800;fontSize=9;align=left;spacingLeft=8;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="810" y="270" width="300" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="sc-j" value="J: DNS Resolve&#10;    Resolver forwards to stale IP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=9;align=left;spacingLeft=8;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="810" y="315" width="300" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="sc-k" value="K: DB Connectivity Probe ← THIS SCENARIO&#10;    Connection pool exhaustion (Error 1040)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E91E63;fontSize=9;fontStyle=1;align=left;spacingLeft=8;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="810" y="360" width="300" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="sc-l" value="L: SSM Health Check&#10;    NACL blocks 443 to SSM VPC endpoints" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFEBE9;strokeColor=#795548;fontSize=9;align=left;spacingLeft=8;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="810" y="405" width="300" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="sc-c" value="C: TLS Fragmentation (Packet Capture)&#10;    ML-KEM oversized ClientHello via TGW+NFW" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9C27B0;fontSize=9;align=left;spacingLeft=8;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="810" y="450" width="300" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="shared-infra" value="Shared Infrastructure:&#10;• Transit Gateway&#10;• Network Firewall&#10;• Traffic Mirror (NLB + Collector)&#10;• S3 + DynamoDB (pcap storage)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=9;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="810" y="500" width="300" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="arrow-mcp-alpha" value="SSM RunShellScript&#10;(runs probe FROM instance)" style="endArrow=classic;html=1;rounded=1;strokeWidth=2;strokeColor=#3F51B5;fontSize=9;fontColor=#3F51B5;labelBackgroundColor=none;entryX=0;entryY=0.5;" parent="1" edge="1">
                    <mxGeometry x="0.2" y="15" relative="1" as="geometry">
                        <mxPoint x="320" y="400" as="sourcePoint"/>
                        <mxPoint x="440" y="210" as="targetPoint"/>
                        <mxPoint as="offset"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="legend-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="790" y="590" width="340" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="legend-title" value="How It Works (Demo Flow)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="870" y="597" width="180" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="legend-flow" value="1. User asks DevOps Agent: &quot;Why can't my app connect to DB?&quot;&#10;2. Agent checks AWS APIs → instance healthy, SG open, params normal&#10;3. Agent can't determine root cause from APIs alone&#10;4. Agent invokes db_connectivity_probe via MCP&#10;5. MCP runs diagnostic script ON svc-alpha via SSM&#10;6. Script attempts MySQL connection → gets Error 1040&#10;7. Script queries SHOW STATUS → Threads_connected=90/82&#10;8. Tool returns: &quot;Pool exhausted, recommend RDS Proxy&quot;&#10;9. Agent presents diagnosis + remediation to user" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=9;fontColor=#000000;spacingLeft=5;" parent="1" vertex="1">
                    <mxGeometry x="800" y="622" width="320" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="eventbridge" value="EventBridge&#10;(every 1 min)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=8;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eventbridge;" parent="1" vertex="1">
                    <mxGeometry x="410" y="700" width="40" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="arrow-eb-lambda" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=1;strokeColor=#666666;" parent="1" edge="1">
