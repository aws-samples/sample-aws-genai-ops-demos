        <!-- Key Issue Callout -->
        <mxCell id="callout" value="⚠️ TLS Fragmentation Issue:&#xa;&#xa;AL2023 curl uses X25519MLKEM768&#xa;→ 1522-byte Client Hello&#xa;→ Exceeds 1460-byte TCP MSS&#xa;→ TLS record fragments across 2 TCP segments&#xa;→ NFW cannot extract SNI&#xa;→ Pass rule doesn't match&#xa;→ Traffic evades inspection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
